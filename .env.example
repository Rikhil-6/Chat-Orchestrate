# Chainlit + OpenSwarm
USE_OPEN_SWARM=false
OPEN_SWARM_BASE_URL=http://localhost:8000
OPEN_SWARM_API_KEY=
OPEN_SWARM_MODEL=codey
OPEN_SWARM_TIMEOUT_SECONDS=90
OPENAI_API_KEY=
CODEX_API_MODEL=gpt-5.3-codex
CLAUDE_API_KEY=
CLAUDE_API_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=
GEMINI_API_MODEL=gemini-2.0-flash

# Project spaces
WORKSPACES_ROOT=./workspaces
WORKSPACE_STATE_PATH=./workspace_state.json
COORDINATION_STATE_PATH=./coordination_state.json
COORDINATION_BACKEND=file
COORDINATION_HTTP_URL=
COORDINATION_HTTP_URLS=
CLUSTER_ID=local
COORDINATION_TOKEN=
COORDINATOR_AUTO_HOST=false
COORDINATOR_HOST=127.0.0.1
COORDINATOR_PORT=8765
MACHINE_ID=
AGENT_BACKENDS=auto
ORCHESTRATOR_TTL_SECONDS=120
WORKER_POLL_SECONDS=5
WORKER_DRY_RUN=true
USE_LOCAL_AGENT_CHAT=true
LOCAL_AGENT_TIMEOUT_SECONDS=180
CODEX_COMMAND=
CLAUDE_COMMAND=
GEMINI_COMMAND=
DELEGATED_TASK_WAIT_SECONDS=90
DELEGATED_TASK_ACK_SECONDS=6

# Orchestration
DEFAULT_AGENT_SET=coordinator,researcher,engineer,reviewer,documenter
